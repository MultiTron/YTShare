  <diagram id="page2" name="2. Authentication Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0" background="none">
      <root>
        <mxCell id="p2-0" />
        <mxCell id="p2-1" parent="p2-0" />
        <mxCell id="p2-title" value="Authentication Flow" style="text;html=1;fontSize=22;fontStyle=1;align=center;fontColor=#000000;fillColor=none;strokeColor=none;" vertex="1" parent="p2-1">
          <mxGeometry x="400" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p2-user" value="User" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontStyle=1;fontSize=13;" vertex="1" parent="p2-1">
          <mxGeometry x="60" y="100" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p2-client" value="Client&#xa;(Angular / Android)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="p2-1">
          <mxGeometry x="300" y="90" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2-firebase" value="Firebase Auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="p2-1">
          <mxGeometry x="580" y="90" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2-backend" value="Spring Boot&#xa;Backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="p2-1">
          <mxGeometry x="840" y="90" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2-db" value="PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontColor=#000000;fontStyle=1;fontSize=12;" vertex="1" parent="p2-1">
          <mxGeometry x="1080" y="80" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2-s1" value="1. Enter email &amp; password" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-user" target="p2-client" parent="p2-1">
          <mxGeometry x="0" y="180" relative="1" as="geometry">
            <mxPoint x="120" y="180" as="sourcePoint" />
            <mxPoint x="380" y="180" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s2" value="2. signInWithEmailAndPassword()" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-client" target="p2-firebase" parent="p2-1">
          <mxGeometry x="0" y="230" relative="1" as="geometry">
            <mxPoint x="380" y="230" as="sourcePoint" />
            <mxPoint x="650" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s3" value="3. Return Firebase ID Token" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-firebase" target="p2-client" parent="p2-1">
          <mxGeometry x="0" y="280" relative="1" as="geometry">
            <mxPoint x="650" y="280" as="sourcePoint" />
            <mxPoint x="380" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-note1" value="Token stored in AuthService (signals)&#xa;or AuthRepository (Android)" style="shape=note;size=15;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontColor=#000000;fontSize=10;align=left;" vertex="1" parent="p2-1">
          <mxGeometry x="100" y="310" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p2-s4" value="4. GET /api/users/me   Authorization: Bearer {token}" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-client" target="p2-backend" parent="p2-1">
          <mxGeometry x="0" y="390" relative="1" as="geometry">
            <mxPoint x="380" y="390" as="sourcePoint" />
            <mxPoint x="910" y="390" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s5" value="5. Verify ID Token (Firebase Admin SDK)" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-backend" target="p2-firebase" parent="p2-1">
          <mxGeometry x="0" y="440" relative="1" as="geometry">
            <mxPoint x="910" y="440" as="sourcePoint" />
            <mxPoint x="650" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s6" value="6. Decoded token (UID, email)" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-firebase" target="p2-backend" parent="p2-1">
          <mxGeometry x="0" y="490" relative="1" as="geometry">
            <mxPoint x="650" y="490" as="sourcePoint" />
            <mxPoint x="910" y="490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-note2" value="FirebaseTokenFilter sets SecurityContext&#xa;with FirebaseAuthenticationToken (ROLE_USER)" style="shape=note;size=15;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontColor=#000000;fontSize=10;align=left;" vertex="1" parent="p2-1">
          <mxGeometry x="830" y="510" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p2-s7" value="7. Find / Create User by Firebase UID" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-backend" target="p2-db" parent="p2-1">
          <mxGeometry x="0" y="580" relative="1" as="geometry">
            <mxPoint x="910" y="580" as="sourcePoint" />
            <mxPoint x="1140" y="580" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s8" value="8. User entity" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-db" target="p2-backend" parent="p2-1">
          <mxGeometry x="0" y="630" relative="1" as="geometry">
            <mxPoint x="1140" y="630" as="sourcePoint" />
            <mxPoint x="910" y="630" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-s9" value="9. 200 OK — User data (DTO)" style="rounded=0;strokeColor=#000000;strokeWidth=1;fontColor=#000000;fontSize=11;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p2-backend" target="p2-client" parent="p2-1">
          <mxGeometry x="0" y="690" relative="1" as="geometry">
            <mxPoint x="910" y="690" as="sourcePoint" />
            <mxPoint x="380" y="690" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="p2-note3" value="AuthInterceptor attaches Bearer token&#xa;to ALL subsequent HTTP requests" style="shape=note;size=15;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontColor=#000000;fontSize=10;align=left;" vertex="1" parent="p2-1">
          <mxGeometry x="100" y="730" width="260" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page3" name="3. Real-Time Chat Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0" background="none">
      <root>
        <mxCell id="p3-0" />
        <mxCell id="p3-1" parent="p3-0" />
        <mxCell id="p3-title" value="Real-Time Chat &amp; Notification Flow" style="text;html=1;fontSize=22;fontStyle=1;align=center;fontColor=#000000;fillColor=none;strokeColor=none;" vertex="1" parent="p3-1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p3-sender" value="Sender&#xa;(Angular / Android)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="60" y="120" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-rest" value="REST API&#xa;MessageController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="400" y="120" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-ws" value="WebSocket Server&#xa;STOMP Broker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="400" y="320" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-db" value="PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="420" y="500" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p3-fcm" value="Firebase Cloud&#xa;Messaging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="780" y="320" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-receiver-on" value="Receiver&#xa;(Online)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="780" y="120" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-receiver-off" value="Receiver&#xa;(Offline / Android)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=13;fontColor=#000000;fontStyle=1;" vertex="1" parent="p3-1">
          <mxGeometry x="780" y="500" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3-e1" value="1. POST /api/messages&#xa;{chatId, content}" style="rounded=1;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="p3-sender" target="p3-rest" parent="p3-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e2" value="2. Save Message" style="rounded=1;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="p3-rest" target="p3-db" parent="p3-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e3" value="3. Broadcast to&#xa;/topic/chat/{chatId}" style="rounded=1;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="p3-rest" target="p3-ws" parent="p3-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e4" value="4. STOMP MESSAGE&#xa;(real-time delivery)" style="rounded=1;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;labelBackgroundColor=#FFFFFF;" edge="1" source="p3-ws" target="p3-receiver-on" parent="p3-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3-e5" value="5. Send FCM push&#xa;(FcmService)" style="rounded=1;strokeColor=#000000;strokeWidth=1.5;fontColor=#000000;fontSize=10;dashed=1;labelBackgroundColor=#FFFFFF;" edge="1" source="p3-rest" target="p3-fcm" parent="p3-1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
