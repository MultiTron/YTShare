# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ytshare
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Firebase Configuration
# Paste your Firebase service account JSON as a single line (escape quotes if needed)
# You can download this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
